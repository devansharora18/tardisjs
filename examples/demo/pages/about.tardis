blueprint About {
  ui {
    <main>
      <h1>About this demo</h1>
      <p>This website is built with tardisjs blueprints.</p>
      <p>It demonstrates routing, state updates, and event handling.</p>

      <nav>
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/demo-post">Dynamic page</a>
      </nav>
    </main>
  }
}
