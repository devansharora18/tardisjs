{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Tardis",
  "scopeName": "source.tardis",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#runtimeHelpers"
    },
    {
      "include": "#events"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#markup"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.tardis",
          "match": "//.*$"
        },
        {
          "name": "comment.block.tardis",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.tardis",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.tardis",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.tardis",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.tardis",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.tardis",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        },
        {
          "name": "constant.language.boolean.tardis",
          "match": "\\b(?:true|false|null|undefined)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.declaration.blueprint.tardis",
          "match": "\\bblueprint\\b"
        },
        {
          "name": "keyword.control.section.tardis",
          "match": "\\b(?:props|state|computed|methods|events|style|ui|script)\\b"
        },
        {
          "name": "storage.type.tardis",
          "match": "\\b(?:string|number|boolean|array|object|function)\\b"
        }
      ]
    },
    "runtimeHelpers": {
      "patterns": [
        {
          "name": "support.function.tardis",
          "match": "\\$(?:if|each|show|fetch|update|toggle|reset|batch|portal|navigate|back|forward|params)\\b"
        }
      ]
    },
    "events": {
      "patterns": [
        {
          "name": "entity.other.attribute-name.event.tardis",
          "match": "@[a-zA-Z_][\\w-]*"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.tardis",
          "match": "=>"
        },
        {
          "name": "keyword.operator.assignment.tardis",
          "match": "="
        },
        {
          "name": "keyword.operator.punctuation.tardis",
          "match": "[:.,]"
        },
        {
          "name": "punctuation.definition.brace.tardis",
          "match": "[{}]"
        },
        {
          "name": "punctuation.definition.bracket.tardis",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.definition.parenthesis.tardis",
          "match": "[()]"
        }
      ]
    },
    "markup": {
      "patterns": [
        {
          "name": "entity.name.tag.tardis",
          "match": "</?[A-Za-z][A-Za-z0-9-]*"
        },
        {
          "name": "entity.other.attribute-name.tardis",
          "match": "\\b[a-zA-Z_:][a-zA-Z0-9_:-]*(?=\\s*=)"
        },
        {
          "name": "meta.embedded.expression.tardis",
          "begin": "\\{",
          "end": "\\}",
          "patterns": [
            {
              "include": "#runtimeHelpers"
            },
            {
              "include": "#numbers"
            },
            {
              "include": "#strings"
            }
          ]
        }
      ]
    }
  }
}